---
import MoveDetailPage from '../../../components/pages/MoveDetailPage.astro';
import { PUBLIC_MOVES } from '../../../lib/pages/moves';
export function getStaticPaths() { return PUBLIC_MOVES.map((move) => ({ params: { family: move.family, move: move.id }, props: { move } })); }
const { move } = Astro.props;
---
<MoveDetailPage locale="en-US" move={move} />
