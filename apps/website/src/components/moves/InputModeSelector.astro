---
import type { LocaleCode } from '../../lib/i18n';
interface Props { locale: LocaleCode; }
const { locale } = Astro.props as Props;
const copy = {
  'en-US': { legend: 'Choose controller', touch: 'Touchscreen', gamepad: 'Gamepad', keyboard: 'Keyboard & mouse' },
  'it-IT': { legend: 'Scegli il controller', touch: 'Touchscreen', gamepad: 'Joystick', keyboard: 'Tastiera e mouse' },
  'es-419': { legend: 'Elige el control', touch: 'Pantalla táctil', gamepad: 'Mando', keyboard: 'Teclado y mouse' },
  'pt-BR': { legend: 'Escolha o controle', touch: 'Tela sensível ao toque', gamepad: 'Controle', keyboard: 'Teclado e mouse' },
  'zh-Hans': { legend: '选择控制方式', touch: '触摸屏', gamepad: '手柄', keyboard: '键盘和鼠标' }
}[locale];
---

<fieldset class="my-7 rounded-[1.75rem] border-2 border-[#4f4337] bg-[#f8f1e7] p-4 shadow-[0_7px_0_rgba(95,82,69,0.22)] sm:p-5" data-input-mode-selector>
  <legend class="px-2 text-[10px] font-black uppercase tracking-[0.24em] text-[#655544]">{copy.legend}</legend>
  <div class="grid gap-3 sm:grid-cols-3">
    <button type="button" class="input-mode-button" data-input-mode="touch" aria-pressed="false">
      <svg viewBox="0 0 32 32" aria-hidden="true"><rect x="8" y="2" width="16" height="28" rx="3"/><circle cx="16" cy="25" r="1.5"/><path d="M16 8v10m0 0-3-3m3 3 3-3"/></svg>
      <span>{copy.touch}</span>
    </button>
    <button type="button" class="input-mode-button" data-input-mode="gamepad" aria-pressed="false">
      <svg viewBox="0 0 32 32" aria-hidden="true"><path d="M9 10h14c4 0 7 4 7 9s-3 7-6 4l-3-3H11l-3 3c-3 3-6 1-6-4s3-9 7-9Z"/><path d="M10 14v6m-3-3h6m9-2h.1m3 3h.1"/></svg>
      <span>{copy.gamepad}</span>
    </button>
    <button type="button" class="input-mode-button" data-input-mode="keyboard" aria-pressed="true">
      <svg viewBox="0 0 32 32" aria-hidden="true"><rect x="2" y="6" width="28" height="19" rx="3"/><path d="M6 11h2m3 0h2m3 0h2m3 0h2m3 0h1M6 16h2m3 0h2m3 0h2m3 0h2m-17 5h20"/></svg>
      <span>{copy.keyboard}</span>
    </button>
  </div>
</fieldset>

<script>
  const buttonMap = {
    touch: { toprock: 'A', footwork: 'B', freeze: 'X', powermove: 'Y' },
    gamepad: { toprock: 'A', footwork: 'B', freeze: 'X', powermove: 'Y' },
    keyboard: { toprock: 'J', footwork: 'K', freeze: 'L', powermove: 'Space' }
  } as const;
  type Mode = keyof typeof buttonMap;
  type Family = keyof typeof buttonMap.touch;
  const storageKey = 'bboyarena:movesInputMode';
  const isMode = (value: string | null): value is Mode =>
    value === 'touch' || value === 'gamepad' || value === 'keyboard';
  const readMode = (): Mode => {
    try {
      const stored = window.localStorage.getItem(storageKey);
      return isMode(stored) ? stored : 'keyboard';
    } catch {
      return 'keyboard';
    }
  };
  const saveMode = (mode: Mode) => {
    try {
      window.localStorage.setItem(storageKey, mode);
    } catch {
      // The selector still works for this page when storage is unavailable.
    }
  };

  document.querySelectorAll<HTMLElement>('[data-input-mode-selector]').forEach((selector) => {
    const buttons = Array.from(selector.querySelectorAll<HTMLButtonElement>('[data-input-mode]'));
    const setMode = (mode: Mode) => {
      buttons.forEach((button) => button.setAttribute('aria-pressed', String(button.dataset.inputMode === mode)));
      document.querySelectorAll<HTMLElement>('[data-control-family]').forEach((control) => {
        const family = control.dataset.controlFamily as Family;
        const value = buttonMap[mode][family];
        const valueNode = control.querySelector<HTMLElement>('[data-control-value]');
        const modeNode = control.querySelector<HTMLElement>('[data-control-mode]');
        if (valueNode) valueNode.textContent = value;
        if (modeNode) modeNode.textContent = mode === 'touch' ? 'Touch' : mode === 'gamepad' ? 'Gamepad' : 'Keyboard';
      });
      document.querySelectorAll<HTMLElement>('[data-control-path]').forEach((path) => {
        const stickPath = path.dataset.stickPath ?? '';
        path.textContent = mode === 'keyboard' ? (path.dataset.keyboardPath ?? stickPath) : stickPath;
      });
    };
    buttons.forEach((button) => button.addEventListener('click', () => {
      const mode = button.dataset.inputMode as Mode;
      setMode(mode);
      saveMode(mode);
    }));
    setMode(readMode());
  });

  window.addEventListener('storage', (event) => {
    if (event.key !== storageKey || !isMode(event.newValue)) return;
    document.querySelectorAll<HTMLElement>('[data-input-mode-selector]').forEach((selector) => {
      const selected = selector.querySelector<HTMLButtonElement>(`[data-input-mode="${event.newValue}"]`);
      selected?.click();
    });
  });
</script>

<style>
  .input-mode-button { min-height: 4.5rem; display: flex; align-items: center; gap: .8rem; border: 2px solid #4f4337; border-radius: 1.1rem; padding: .8rem 1rem; color: #453a2f; background: #eee3d3; font-size: .72rem; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; transition: transform .15s, background .15s, color .15s; }
  .input-mode-button:hover { transform: translateY(-2px); }
  .input-mode-button[aria-pressed="true"] { color: #f8f1e7; background: #2f281f; box-shadow: inset 0 0 0 2px #c98656; }
  .input-mode-button svg { width: 2rem; height: 2rem; flex: none; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
</style>
