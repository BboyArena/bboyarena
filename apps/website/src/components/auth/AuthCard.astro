---
import Layout from '../layout/Layout.astro';

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  pagePath: string;
}

const { title, description, eyebrow, pagePath } = Astro.props;
---

<Layout
  title={`${title} | BboyArena.org`}
  description={description}
  pagePath={pagePath}
  locale="en-US"
  plainBackground
>
  <section class="mx-auto grid w-full max-w-5xl gap-6 py-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <div class="space-y-4">
      <p class="text-[11px] font-black uppercase tracking-[0.28em] text-[#756553]">{eyebrow}</p>
      <h1 class="max-w-xl text-4xl font-black uppercase leading-[0.9] text-[#211b15] sm:text-6xl">
        {title}
      </h1>
      <p class="max-w-xl text-base leading-7 text-[#4f4337] sm:text-lg">
        {description}
      </p>
    </div>

    <div class="street-panel rounded-[1.25rem] p-4 sm:p-6">
      <slot />
    </div>
  </section>
</Layout>
