---
import { getSiteCopy, type LocaleCode } from '../../lib/i18n';
import { supportPlatforms } from '../../lib/support';

interface Props {
  locale?: LocaleCode;
}

const { locale = 'en-US' } = Astro.props;
const copy = getSiteCopy(locale).footer;
---

{supportPlatforms.length > 0 && (
  <aside
    class="flex w-full flex-col items-center gap-3 rounded-[1.25rem] border-2 border-[#4f4337]/70 bg-[#f4ebdf] px-4 py-4 text-center sm:flex-row sm:justify-between sm:text-left"
    aria-labelledby="support-project-title"
  >
    <div class="max-w-xl">
      <p id="support-project-title" class="text-[11px] font-black uppercase tracking-[0.22em] text-[#2d251d]">
        {copy.supportTitle}
      </p>
      <p class="mt-1 text-[12px] leading-relaxed text-[#5f5346]">{copy.supportDescription}</p>
    </div>

    <div class="flex flex-wrap justify-center gap-2 sm:shrink-0 sm:justify-end">
      {supportPlatforms.map((platform) => (
        <a
          href={platform.href}
          class="street-button street-button-primary inline-flex min-h-10 items-center justify-center gap-2 rounded-full px-4 text-[10px] font-black uppercase tracking-[0.18em]"
          target="_blank"
          rel="noreferrer noopener"
          aria-label={`${copy.supportCta} ${platform.label}`}
        >
          {platform.id === 'buyMeACoffee' && (
            <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true">
              <path d="M6.5 5.5h10l-1 10a3 3 0 0 1-3 2.7h-2a3 3 0 0 1-3-2.7l-1-10Zm10.2 2h1.1a2.7 2.7 0 0 1 0 5.4h-1.7M5 20h12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          )}
          {platform.id === 'patreon' && (
            <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true">
              <path d="M5 4.5v15M13.5 4.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11Z" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
            </svg>
          )}
          <span>{platform.label}</span>
        </a>
      ))}
    </div>
  </aside>
)}
