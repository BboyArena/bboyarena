---
import Layout from '../layout/Layout.astro';

interface Props {
  locale: import('../../lib/i18n').LocaleCode;
  pagePath: string;
}

const { locale, pagePath } = Astro.props as Props;
const trackingKey = 'bboyarena-no-tracking';
---

<Layout
  title="LocalStorage Inspector"
  description="Public privacy helper for inspecting localStorage and toggling the no-tracking flag for this browser."
  locale={locale}
  pagePath={pagePath}
  noindex
>
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
    <section class="rounded-[2rem] border border-slate-200 bg-white/95 p-6 shadow-[0_20px_60px_rgba(15,23,42,0.1)] backdrop-blur sm:p-8">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <p class="text-[10px] font-black uppercase tracking-[0.38em] text-slate-500">Privacy helper</p>
          <h1 class="mt-3 text-4xl font-black uppercase leading-[0.92] tracking-[0.14em] text-slate-950 sm:text-6xl">
            LocalStorage
            <span class="block text-slate-500">inspector</span>
          </h1>
          <p class="mt-4 text-sm leading-7 text-slate-600 sm:text-base">
            Usa questa pagina per leggere, aggiornare e pulire le chiavi del browser senza aprire gli strumenti di sviluppo.
            Il flag <code class="rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.85em] text-slate-800">{trackingKey}</code>
            disattiva il tracking su questo browser.
          </p>
        </div>

        <div class="grid gap-2 text-[10px] font-black uppercase tracking-[0.28em] text-slate-500">
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-2">read / write</span>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-2">no tracking</span>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-2">privacy page</span>
        </div>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr]">
      <div class="grid gap-6">
        <section class="rounded-[1.75rem] border border-slate-200 bg-slate-950 p-5 text-white shadow-[0_12px_40px_rgba(15,23,42,0.12)] sm:p-6">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-400">Tracking state</p>
              <h2 class="mt-2 text-2xl font-black uppercase tracking-[0.14em]">Browser privacy</h2>
            </div>
            <span
              class="rounded-full bg-white/10 px-3 py-1 text-[10px] font-black uppercase tracking-[0.26em] text-slate-200"
              data-tracking-status
            >
              loading
            </span>
          </div>

          <div class="mt-5 grid gap-3 rounded-[1.4rem] border border-white/10 bg-white/5 p-4 text-sm leading-7 text-slate-200">
            <p>Abilitando il no tracking, questo browser smette di inviare eventi analytics alla prossima navigazione.</p>
            <p class="text-slate-300">Lo stato viene salvato in localStorage, così puoi usare lo stesso profilo anche nei test futuri.</p>
          </div>

          <div class="mt-5 flex flex-wrap gap-3">
            <button
              type="button"
              class="rounded-full bg-emerald-400 px-4 py-2 text-xs font-black uppercase tracking-[0.26em] text-slate-950 transition hover:-translate-y-0.5"
              data-enable-no-tracking
            >
              Enable no tracking
            </button>
            <button
              type="button"
              class="rounded-full border border-white/20 bg-white/5 px-4 py-2 text-xs font-black uppercase tracking-[0.26em] text-white transition hover:-translate-y-0.5"
              data-disable-no-tracking
            >
              Disable no tracking
            </button>
          </div>
        </section>

        <section class="rounded-[1.75rem] border border-slate-200 bg-white p-5 shadow-[0_12px_40px_rgba(15,23,42,0.08)] sm:p-6">
          <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-500">Storage tools</p>
          <div class="mt-4 flex flex-wrap gap-3">
            <button
              type="button"
              class="rounded-full bg-slate-950 px-4 py-2 text-xs font-black uppercase tracking-[0.26em] text-white"
              data-refresh
            >
              Refresh
            </button>
            <button
              type="button"
              class="rounded-full border border-slate-300 bg-white px-4 py-2 text-xs font-black uppercase tracking-[0.26em] text-slate-800"
              data-clear-all
            >
              Clear all
            </button>
          </div>

          <div class="mt-5 grid gap-3">
            <label class="grid gap-2">
              <span class="text-[10px] font-black uppercase tracking-[0.26em] text-slate-500">Key</span>
              <input
                type="text"
                value={trackingKey}
                class="rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm outline-none transition placeholder:text-slate-400 focus:border-sky-500 focus:ring-4 focus:ring-sky-100"
                data-entry-key
              />
            </label>
            <label class="grid gap-2">
              <span class="text-[10px] font-black uppercase tracking-[0.26em] text-slate-500">Value</span>
              <textarea
                rows="4"
                class="rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm outline-none transition placeholder:text-slate-400 focus:border-sky-500 focus:ring-4 focus:ring-sky-100"
                data-entry-value
              >1</textarea>
            </label>
            <div class="flex flex-wrap gap-3">
              <button
                type="button"
                class="rounded-full bg-emerald-500 px-4 py-2 text-xs font-black uppercase tracking-[0.26em] text-white"
                data-save-entry
              >
                Save entry
              </button>
              <button
                type="button"
                class="rounded-full border border-rose-200 bg-rose-50 px-4 py-2 text-xs font-black uppercase tracking-[0.26em] text-rose-700"
                data-delete-entry
              >
                Delete entry
              </button>
            </div>
          </div>
        </section>
      </div>

      <section class="rounded-[1.75rem] border border-slate-200 bg-white p-5 shadow-[0_12px_40px_rgba(15,23,42,0.08)] sm:p-6">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <div>
            <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-500">Current entries</p>
            <h2 class="mt-2 text-2xl font-black uppercase tracking-[0.14em] text-slate-950">Stored keys</h2>
          </div>
          <span class="rounded-full bg-slate-100 px-3 py-1 text-[10px] font-black uppercase tracking-[0.26em] text-slate-700" data-entry-count>
            0 items
          </span>
        </div>

        <div class="mt-5 overflow-hidden rounded-[1.4rem] border border-slate-200 bg-slate-50">
          <div class="overflow-x-auto">
            <table class="w-full border-collapse text-left">
              <thead>
                <tr class="border-b border-slate-200 bg-slate-100 text-[10px] uppercase tracking-[0.28em] text-slate-500">
                  <th class="w-[32%] py-4 px-4">Key</th>
                  <th class="py-4 px-4">Value</th>
                  <th class="w-28 py-4 px-4 text-right">Action</th>
                </tr>
              </thead>
              <tbody data-storage-table>
                <tr>
                  <td class="py-8 px-4 text-sm text-slate-500" colspan="3">Loading storage...</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </section>
  </div>

  <script is:inline>
    (() => {
      const init = () => {
        const trackingKey = 'bboyarena-no-tracking';
        const storageTable = document.querySelector('[data-storage-table]');
        const entryCount = document.querySelector('[data-entry-count]');
        const trackingStatus = document.querySelector('[data-tracking-status]');
        const keyInput = document.querySelector('[data-entry-key]');
        const valueInput = document.querySelector('[data-entry-value]');
        const refreshButton = document.querySelector('[data-refresh]');
        const clearAllButton = document.querySelector('[data-clear-all]');
        const saveButton = document.querySelector('[data-save-entry]');
        const deleteButton = document.querySelector('[data-delete-entry]');
        const enableTrackingButton = document.querySelector('[data-enable-no-tracking]');
        const disableTrackingButton = document.querySelector('[data-disable-no-tracking]');

        if (
          !storageTable ||
          !entryCount ||
          !trackingStatus ||
          !keyInput ||
          !valueInput ||
          !refreshButton ||
          !clearAllButton ||
          !saveButton ||
          !deleteButton ||
          !enableTrackingButton ||
          !disableTrackingButton
        ) {
          return;
        }

        const readEntries = () => {
          const entries = [];
          for (let index = 0; index < window.localStorage.length; index += 1) {
            const key = window.localStorage.key(index);
            if (key === null) continue;
            entries.push([key, window.localStorage.getItem(key) ?? '']);
          }

          return entries.sort(([a], [b]) => a.localeCompare(b));
        };

        const updateTrackingState = () => {
          const isEnabled = window.localStorage.getItem(trackingKey) === '1';
          trackingStatus.textContent = isEnabled ? 'no tracking on' : 'tracking on';
          trackingStatus.className = isEnabled
            ? 'rounded-full bg-emerald-400/15 px-3 py-1 text-[10px] font-black uppercase tracking-[0.26em] text-emerald-300'
            : 'rounded-full bg-rose-400/15 px-3 py-1 text-[10px] font-black uppercase tracking-[0.26em] text-rose-300';
        };

        const render = () => {
          const entries = readEntries();
          entryCount.textContent = `${entries.length} ${entries.length === 1 ? 'item' : 'items'}`;
          updateTrackingState();

          storageTable.replaceChildren(
            ...entries.map(([key, value]) => {
              const row = document.createElement('tr');
              row.className = key === trackingKey ? 'border-b border-slate-200 bg-emerald-50/80' : 'border-b border-slate-200 bg-white';

              const keyCell = document.createElement('td');
              keyCell.className = 'py-4 px-4 align-top text-sm font-semibold text-slate-950';
              keyCell.textContent = key;

              const valueCell = document.createElement('td');
              valueCell.className = 'py-4 px-4 align-top text-sm text-slate-600';
              valueCell.style.whiteSpace = 'pre-wrap';
              valueCell.style.wordBreak = 'break-word';
              valueCell.textContent = value || '""';

              const actionCell = document.createElement('td');
              actionCell.className = 'py-4 px-4 text-right';

              const button = document.createElement('button');
              button.type = 'button';
              button.className = 'rounded-full border border-slate-300 bg-white px-3 py-1.5 text-[10px] font-black uppercase tracking-[0.24em] text-slate-700 transition hover:-translate-y-0.5';
              button.textContent = 'Delete';
              button.addEventListener('click', () => {
                window.localStorage.removeItem(key);
                render();
              });

              actionCell.append(button);
              row.append(keyCell, valueCell, actionCell);
              return row;
            })
          );

          if (!entries.length) {
            const row = document.createElement('tr');
            const cell = document.createElement('td');
            cell.colSpan = 3;
            cell.className = 'py-8 px-4 text-sm text-slate-500';
            cell.textContent = 'No localStorage entries found.';
            row.append(cell);
            storageTable.replaceChildren(row);
          }
        };

        const saveEntry = () => {
          const key = keyInput.value.trim();
          if (!key) return;

          window.localStorage.setItem(key, valueInput.value);
          render();
        };

        const deleteEntry = () => {
          const key = keyInput.value.trim();
          if (!key) return;

          window.localStorage.removeItem(key);
          render();
        };

        const toggleTracking = (enabled) => {
          if (enabled) {
            window.localStorage.setItem(trackingKey, '1');
          } else {
            window.localStorage.removeItem(trackingKey);
          }

          render();
        };

        refreshButton.addEventListener('click', render);
        clearAllButton.addEventListener('click', () => {
          if (!window.confirm('Clear every localStorage key for this origin?')) return;
          window.localStorage.clear();
          render();
        });
        saveButton.addEventListener('click', saveEntry);
        deleteButton.addEventListener('click', deleteEntry);
        enableTrackingButton.addEventListener('click', () => toggleTracking(true));
        disableTrackingButton.addEventListener('click', () => toggleTracking(false));
        window.addEventListener('storage', render);

        render();
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
      } else {
        init();
      }
    })();
  </script>
</Layout>
