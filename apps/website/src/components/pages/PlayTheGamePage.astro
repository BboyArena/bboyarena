---
import Layout from '../layout/Layout.astro';
import { buildLocalizedAlternates, getLocaleSwitcherLinks, type LocaleCode } from '../../lib/i18n';

interface Props {
  locale?: LocaleCode;
}

const { locale = 'en-US' } = Astro.props;
const defaultGameEmbedUrl = import.meta.env.DEV ? 'http://localhost:4322/' : 'https://bboyarena.org/game/';
const gameEmbedUrl = import.meta.env.PUBLIC_GAME_EMBED_URL?.trim() || defaultGameEmbedUrl;
const hasGameEmbed = Boolean(gameEmbedUrl);
const earlyViewNotice: Record<LocaleCode, string> = {
  'en-US': 'Public early view · Features and controls are still in active development.',
  'it-IT': 'Anteprima pubblica · Funzionalità e controlli sono ancora in sviluppo attivo.',
  'es-419': 'Vista previa pública · Las funciones y los controles siguen en desarrollo activo.',
  'pt-BR': 'Prévia pública · Recursos e controles ainda estão em desenvolvimento ativo.',
  'zh-Hans': '公开抢先体验 · 功能和操作仍在持续开发中。'
};
const pwaGateCopy: Record<LocaleCode, { title: string; text: string; install: string; fallback: string }> = {
  'en-US': {
    title: 'Install the app to unlock the game',
    text: 'This public early test runs only inside the installed BboyArena PWA.',
    install: 'Install BboyArena',
    fallback: 'Use your browser menu and choose “Install app” or “Add to Home Screen”, then open BboyArena from the installed app.'
  },
  'it-IT': {
    title: 'Installa l’app per sbloccare il gioco',
    text: 'Questo test pubblico iniziale funziona solo nella PWA BboyArena installata.',
    install: 'Installa BboyArena',
    fallback: 'Dal menu del browser scegli “Installa app” o “Aggiungi a schermata Home”, poi apri BboyArena dall’app installata.'
  },
  'es-419': {
    title: 'Instala la app para desbloquear el juego',
    text: 'Esta prueba pública inicial funciona solo dentro de la PWA BboyArena instalada.',
    install: 'Instalar BboyArena',
    fallback: 'En el menú del navegador elige “Instalar aplicación” o “Agregar a pantalla de inicio” y abre BboyArena desde la app instalada.'
  },
  'pt-BR': {
    title: 'Instale o app para desbloquear o jogo',
    text: 'Este teste público inicial funciona somente dentro do PWA BboyArena instalado.',
    install: 'Instalar BboyArena',
    fallback: 'No menu do navegador, escolha “Instalar app” ou “Adicionar à tela inicial” e abra o BboyArena pelo app instalado.'
  },
  'zh-Hans': {
    title: '安装应用以解锁游戏',
    text: '此公开早期测试仅可在已安装的 BboyArena PWA 中运行。',
    install: '安装 BboyArena',
    fallback: '请从浏览器菜单选择“安装应用”或“添加到主屏幕”，然后从已安装的应用打开 BboyArena。'
  }
};

const copy = {
  eyebrow: 'Browser game showroom',
  title: 'Play the standalone game inside the website.',
  lead:
    'This page embeds the standalone BboyArena game runtime in a website shell, so we can test the future player-facing experience without mixing the game code back into Astro.',
  seoTitle: 'Play the BboyArena game prototype',
  seoDescription:
    'Open the BboyArena standalone game prototype in an embedded showroom page with setup notes, controls, and development instructions.',
  launchLabel: 'Embedded runtime',
  launchTitle: 'Game iframe',
  launchText:
    'In development, keep the game server running on port 4322 and the website server on port 4321. The iframe below will load the standalone game app.',
  missingTitle: 'Game server not configured',
  missingText:
    'Set PUBLIC_GAME_EMBED_URL to the standalone game URL, or run the website in development where the default is http://localhost:4322/.',
  setupTitle: 'How to run it locally',
  setupLead: 'Use two terminals so the website and game stay independent.',
  steps: [
    {
      label: 'Terminal 1',
      command: 'npm run game:dev',
      description: 'Starts the standalone game app on http://localhost:4322/.'
    },
    {
      label: 'Terminal 2',
      command: 'npm run dev',
      description: 'Starts the Astro website on http://localhost:4321/.'
    },
    {
      label: 'Open',
      command: 'http://localhost:4321/play-the-game',
      description: 'Loads the website showroom and embeds the running game app.'
    }
  ],
  notesTitle: 'Gameplay notes',
  notes: [
    'The menu, splashscreen, settings, credits, HUD, and fullscreen control come from the standalone game runtime.',
    'The Three.js/R3F scene is still loaded only when the play flow enters a gameplay screen.',
    'This iframe is a showroom and integration test, not a production distribution strategy yet.',
    'If the iframe is blank in development, check that npm run game:dev is running.'
  ],
  cta: 'Open standalone game',
  fallbackCta: 'Start game dev server'
};

const pagePath = '/play-the-game';
---

<Layout
  title={copy.seoTitle}
  description={copy.seoDescription}
  locale={locale}
  pagePath={pagePath}
  alternateLinks={buildLocalizedAlternates(pagePath)}
  localeSwitcherLinks={getLocaleSwitcherLinks(pagePath)}
  fullBleedMain
>
  <section class="play-showroom mx-auto flex w-full max-w-7xl flex-col gap-6">
    <div class="play-showroom__hero">
      <div class="max-w-3xl">
        <div class="play-showroom__early-notice">{earlyViewNotice[locale]}</div>
        <p class="play-showroom__eyebrow">{copy.eyebrow}</p>
        <h1>{copy.title}</h1>
        <p>{copy.lead}</p>
      </div>
      {gameEmbedUrl && (
        <a href={gameEmbedUrl} target="_blank" rel="noreferrer noopener" class="play-showroom__hero-link" data-pwa-game-access hidden>
          {copy.cta}
        </a>
      )}
    </div>

    <div class="play-showroom__stage" aria-label={copy.launchLabel}>
      <div class="play-showroom__stage-header">
        <div>
          <p>{copy.launchLabel}</p>
          <h2>{copy.launchTitle}</h2>
        </div>
        <span>{hasGameEmbed ? gameEmbedUrl : 'PUBLIC_GAME_EMBED_URL missing'}</span>
      </div>

      <div class="play-showroom__screen">
        {hasGameEmbed ? (
          <>
            <iframe
              data-src={gameEmbedUrl}
              title="BboyArena standalone game"
              class="play-showroom__iframe"
              loading="lazy"
              allow="fullscreen; gamepad"
              allowfullscreen
              sandbox="allow-scripts allow-same-origin allow-pointer-lock allow-forms allow-popups"
              data-pwa-game-frame
              hidden
            ></iframe>
            <div class="play-showroom__pwa-gate" data-pwa-game-gate>
              <p>{pwaGateCopy[locale].title}</p>
              <span>{pwaGateCopy[locale].text}</span>
              <button type="button" data-pwa-game-install>{pwaGateCopy[locale].install}</button>
              <small data-pwa-game-fallback hidden>{pwaGateCopy[locale].fallback}</small>
            </div>
          </>
        ) : (
          <div class="play-showroom__missing">
            <p>{copy.missingTitle}</p>
            <span>{copy.missingText}</span>
          </div>
        )}
      </div>
    </div>

    <div class="play-showroom__grid">
      <article class="play-showroom__panel play-showroom__panel--setup">
        <p class="play-showroom__eyebrow">{copy.setupTitle}</p>
        <h2>{copy.setupLead}</h2>
        <ol>
          {copy.steps.map((step) => (
            <li>
              <span>{step.label}</span>
              <code>{step.command}</code>
              <p>{step.description}</p>
            </li>
          ))}
        </ol>
      </article>

      <article class="play-showroom__panel">
        <p class="play-showroom__eyebrow">{copy.notesTitle}</p>
        <h2>What this page proves</h2>
        <ul>
          {copy.notes.map((note) => (
            <li>{note}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>
</Layout>

<script>
  interface InstallPromptEvent extends Event {
    prompt: () => Promise<void>;
    userChoice: Promise<{ outcome: 'accepted' | 'dismissed' }>;
  }

  const displayModeQuery = window.matchMedia('(display-mode: standalone)');
  const frame = document.querySelector<HTMLIFrameElement>('[data-pwa-game-frame]');
  const gate = document.querySelector<HTMLElement>('[data-pwa-game-gate]');
  const installButton = document.querySelector<HTMLButtonElement>('[data-pwa-game-install]');
  const fallback = document.querySelector<HTMLElement>('[data-pwa-game-fallback]');
  const accessLinks = document.querySelectorAll<HTMLElement>('[data-pwa-game-access]');
  let installPrompt: InstallPromptEvent | undefined;

  const syncPwaGameAccess = () => {
    const isStandalone =
      displayModeQuery.matches ||
      (navigator as Navigator & { standalone?: boolean }).standalone === true;

    if (!isStandalone) return;

    if (frame && !frame.src) {
      frame.src = frame.dataset.src ?? '';
    }
    frame?.removeAttribute('hidden');
    gate?.setAttribute('hidden', '');
    accessLinks.forEach((link) => link.removeAttribute('hidden'));
  };

  window.addEventListener('beforeinstallprompt', (event) => {
    event.preventDefault();
    installPrompt = event as InstallPromptEvent;
  });

  installButton?.addEventListener('click', async () => {
    if (!installPrompt) {
      fallback?.removeAttribute('hidden');
      return;
    }

    await installPrompt.prompt();
    await installPrompt.userChoice;
    installPrompt = undefined;
  });

  syncPwaGameAccess();
  window.addEventListener('pageshow', syncPwaGameAccess);
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') syncPwaGameAccess();
  });
  displayModeQuery.addEventListener?.('change', syncPwaGameAccess);
</script>

<style>
  .play-showroom {
    color: #2f281f;
  }

  .play-showroom__hero,
  .play-showroom__panel,
  .play-showroom__stage {
    border: 2px solid #4f4337;
    background:
      linear-gradient(180deg, rgba(248, 241, 231, 0.96), rgba(231, 218, 198, 0.94)),
      repeating-linear-gradient(0deg, rgba(95, 82, 69, 0.05) 0 1px, transparent 1px 6px);
    box-shadow: 0 10px 0 rgba(95, 82, 69, 0.35);
  }

  .play-showroom__hero {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    border-radius: 1.75rem;
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .play-showroom__eyebrow {
    margin: 0 0 0.75rem;
    color: #806a52;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }

  .play-showroom__early-notice {
    display: inline-flex;
    margin-bottom: 1rem;
    border: 1px solid rgba(79, 67, 55, 0.42);
    border-radius: 999px;
    background: rgba(163, 185, 90, 0.22);
    color: #4d5928;
    font-size: 0.62rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    line-height: 1.4;
    padding: 0.5rem 0.75rem;
    text-transform: uppercase;
  }

  .play-showroom h1,
  .play-showroom h2 {
    margin: 0;
    color: #2a241d;
    font-weight: 950;
    letter-spacing: 0.12em;
    line-height: 0.96;
    text-transform: uppercase;
  }

  .play-showroom h1 {
    max-width: 52rem;
    font-size: clamp(2rem, 6vw, 5rem);
  }

  .play-showroom h2 {
    font-size: clamp(1.15rem, 2.4vw, 1.85rem);
  }

  .play-showroom p {
    margin: 1rem 0 0;
    max-width: 48rem;
    color: #574b3d;
    font-size: 1rem;
    line-height: 1.7;
  }

  .play-showroom__hero-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    border: 2px solid #2f281f;
    border-radius: 999px;
    background: linear-gradient(180deg, #f5d35a, #d59b13);
    box-shadow: 0 5px 0 #2f281f;
    color: #211a14;
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.24em;
    padding: 0.85rem 1.25rem;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .play-showroom__hero-link:hover {
    box-shadow: 0 3px 0 #2f281f;
    transform: translateY(2px);
  }

  .play-showroom__stage {
    overflow: hidden;
    border-radius: 1.75rem;
    background:
      radial-gradient(circle at 50% 0%, rgba(244, 190, 36, 0.16), transparent 34%),
      linear-gradient(180deg, #17130f, #070706 58%, #050505);
  }

  .play-showroom__stage-header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 2px solid rgba(248, 241, 231, 0.16);
    padding: 1rem clamp(1rem, 2vw, 1.4rem);
    color: #f8f1e7;
  }

  .play-showroom__stage-header p {
    margin: 0 0 0.35rem;
    color: #f4be24;
    font-size: 0.62rem;
    font-weight: 950;
    letter-spacing: 0.32em;
    line-height: 1;
    text-transform: uppercase;
  }

  .play-showroom__stage-header h2 {
    color: #f8f1e7;
    font-size: clamp(1rem, 2vw, 1.45rem);
  }

  .play-showroom__stage-header span {
    max-width: 100%;
    overflow: hidden;
    border: 1px solid rgba(248, 241, 231, 0.18);
    background: rgba(255, 255, 255, 0.06);
    color: #d8c8ad;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 0.45rem 0.65rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .play-showroom__screen {
    aspect-ratio: 16 / 9;
    width: 100%;
    overflow: hidden;
    background:
      radial-gradient(circle at center, rgba(244, 190, 36, 0.1), transparent 30%),
      #050505;
  }

  .play-showroom__iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    background: #050505;
  }

  .play-showroom__iframe[hidden],
  .play-showroom__hero-link[hidden],
  .play-showroom__pwa-gate[hidden],
  .play-showroom__pwa-gate small[hidden] {
    display: none !important;
  }

  .play-showroom__pwa-gate {
    display: grid;
    height: 100%;
    place-content: center;
    justify-items: center;
    gap: 1rem;
    padding: 2rem;
    text-align: center;
  }

  .play-showroom__pwa-gate p {
    margin: 0;
    color: #f8f1e7;
    font-size: clamp(1.25rem, 3vw, 2.25rem);
    font-weight: 950;
    letter-spacing: 0.14em;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .play-showroom__pwa-gate span,
  .play-showroom__pwa-gate small {
    max-width: 38rem;
    color: #d8c8ad;
    line-height: 1.65;
  }

  .play-showroom__pwa-gate button {
    min-height: 3rem;
    border: 2px solid #f8f1e7;
    border-radius: 999px;
    background: linear-gradient(180deg, #f5d35a, #d59b13);
    box-shadow: 0 5px 0 rgba(0, 0, 0, 0.72);
    color: #211a14;
    cursor: pointer;
    font: inherit;
    font-size: 0.7rem;
    font-weight: 950;
    letter-spacing: 0.2em;
    padding: 0.8rem 1.2rem;
    text-transform: uppercase;
  }

  .play-showroom__missing {
    display: grid;
    height: 100%;
    place-items: center;
    padding: 2rem;
    text-align: center;
  }

  .play-showroom__missing p {
    margin: 0;
    color: #f8f1e7;
    font-size: clamp(1.25rem, 3vw, 2.25rem);
    font-weight: 950;
    letter-spacing: 0.16em;
    line-height: 1;
    text-transform: uppercase;
  }

  .play-showroom__missing span {
    display: block;
    max-width: 34rem;
    color: #d8c8ad;
    line-height: 1.7;
  }

  .play-showroom__grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .play-showroom__panel {
    border-radius: 1.5rem;
    padding: clamp(1.1rem, 2.5vw, 1.6rem);
  }

  .play-showroom__panel ol,
  .play-showroom__panel ul {
    display: grid;
    gap: 0.85rem;
    margin: 1.25rem 0 0;
    padding: 0;
  }

  .play-showroom__panel li {
    list-style: none;
    border: 1px solid rgba(79, 67, 55, 0.22);
    background: rgba(255, 255, 255, 0.34);
    color: #4f4337;
    line-height: 1.6;
    padding: 0.85rem;
  }

  .play-showroom__panel li span {
    display: block;
    color: #806a52;
    font-size: 0.62rem;
    font-weight: 950;
    letter-spacing: 0.26em;
    text-transform: uppercase;
  }

  .play-showroom__panel code {
    display: inline-block;
    margin-top: 0.45rem;
    border: 1px solid rgba(47, 40, 31, 0.24);
    background: #211a14;
    color: #f4be24;
    font-size: 0.82rem;
    font-weight: 850;
    padding: 0.35rem 0.5rem;
  }

  .play-showroom__panel li p {
    margin-top: 0.45rem;
    font-size: 0.92rem;
  }

  @media (max-width: 800px) {
    .play-showroom__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (orientation: portrait) {
    .play-showroom__screen {
      width: min(100%, calc(100svh * 9 / 16));
      aspect-ratio: 9 / 16;
      margin-inline: auto;
    }
  }
</style>
